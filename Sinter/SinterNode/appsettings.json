{
  "SinterNode": {
    "StateFilePath": "/var/lib/sinter-node/config/node-state.json",
    "ApiKeyFilePath": "/var/lib/sinter-node/config/client_secret",
    "ManagedAppsRoot": "/var/lib/sinter-node/apps",
    "NodeInstallRoot": "/opt/sinter-node",
    "NodeReleaseRoot": "/var/lib/sinter-node/node",
    "SystemdUnitDirectory": "/etc/systemd/system",
    "DotnetPath": "/usr/local/bin/dotnet",
    "SelfServiceName": "sinter-node.service",
    "SelfProjectPath": "Sinter/SinterNode/SinterNode.csproj",
    "DefaultSourceRepository": "https://github.com/Jeffe747/Sinter.git",
    "RetainedReleaseCount": 5
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
