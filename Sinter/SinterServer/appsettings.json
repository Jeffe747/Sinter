{
  "SinterServer": {
    "DatabasePath": "./data/sinter-server.db",
    "PollIntervalSeconds": 30,
    "ServerName": "SinterServer",
    "SelfUpdateScriptPath": "/opt/sinter-server/current/update.sh",
    "SelfUpdateLogPath": "/var/log/sinter-server-self-update.log",
    "DefaultSourceRepository": "https://github.com/Jeffe747/Sinter.git",
    "DefaultSourceBranch": "main"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
