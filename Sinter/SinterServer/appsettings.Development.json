{
  "SinterServer": {
    "DatabasePath": "./.dev/sinter-server.db",
    "PollIntervalSeconds": 300,
    "ServerName": "SinterServer (Development)",
    "TelemetryRetentionDays": 21,
    "TelemetrySampleIntervalSeconds": 300,
    "SelfUpdateScriptPath": "./update.sh",
    "SelfUpdateLogPath": "./.dev/sinter-server-self-update.log",
    "DefaultSourceRepository": "https://github.com/Jeffe747/Sinter.git",
    "DefaultSourceBranch": "main"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
